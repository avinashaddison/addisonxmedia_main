# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real secrets.

# ─── Required ────────────────────────────────────────────────────────────────

# Neon Postgres connection string (pooler endpoint, ?sslmode=require)
DATABASE_URL=postgres://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# 32+ char random string. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-32-byte-random-string

# Public base URL of the API/auth server.
# Local dev:  http://localhost:3001
# Production: https://your-service.onrender.com
BETTER_AUTH_URL=http://localhost:3001

# 32-byte hex used by server/crypto.ts to encrypt sensitive columns (Meta tokens, etc).
# Generate: openssl rand -hex 32
MASTER_KEY=replace-with-64-hex-chars

# ─── Local-dev only (production uses Render's $PORT and same-origin) ─────────

PORT=3001
ALLOWED_ORIGINS=http://localhost:4173,http://localhost:5173,http://localhost:8080

# ─── Optional ────────────────────────────────────────────────────────────────

# Meta/WhatsApp webhook verification — whatever value you set in Meta dashboard
META_WEBHOOK_VERIFY_TOKEN=

# ─── Meta Ads OAuth (one-click "Continue with Facebook" for customers) ────────
#
# Without these three, the ads-connect dialog falls back to manual System User
# token paste. With them, customers can connect in one click via Facebook Login.
#
# Setup:
#   1) developers.facebook.com → Create App → "Business" type
#   2) Add product → "Facebook Login for Business"
#   3) Settings → Basic: copy App ID + App Secret
#   4) Facebook Login → Settings → Valid OAuth Redirect URIs: add the exact
#      callback URL (must match META_OAUTH_REDIRECT_URI below)
#   5) Add ads_management, ads_read, business_management permissions
#   6) Until App Review is approved, only Admins/Developers/Testers listed in
#      App Dashboard → Roles can complete the OAuth flow.
META_APP_ID=
META_APP_SECRET=
# Local dev:  http://localhost:3001/api/ads/oauth/callback
# Production: https://your-domain.com/api/ads/oauth/callback
META_OAUTH_REDIRECT_URI=

# ─── OpenAI (powers Addison AI: reply suggestions, ad copy, follow-ups) ──────
#
# Platform-managed key — billed to AddisonX, gated per workspace by plan caps
# in server/lib/ai-usage.ts (Starter: 50/mo, Growth: 5,000/mo, Enterprise: ∞).
# Without this key, AI features return 503 "AI not configured" so the rest of
# the app keeps working.
#
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Razorpay live refund — only set if you want live API calls (otherwise refunds
# are audit-only). The corresponding public key id is stored as a row in the
# system_setting table, manageable from /admin/settings.
RAZORPAY_KEY_SECRET=

# smtp.dev sandbox API key — for capturing/testing outbound mail.
# IMPORTANT: smtp.dev is a SANDBOX — emails never reach real recipients.
# For real delivery, sign up for Resend/Brevo/SES and add their key here.
SMTPDEV_API_KEY=

# Resend (real transactional email — signup confirm, password reset, staff
# invite, suspension, refund). Get at resend.com → API Keys. If blank,
# emails are logged to stdout instead of sent.
RESEND_API_KEY=
# Verified sender on the Resend dashboard. Friendly-name format works:
#   "Addison X Media <noreply@addisonxmedia.com>"
# If blank, falls back to onboarding@resend.dev (only delivers to your
# Resend signup email — fine for testing, not for production).
RESEND_FROM=

# Comma-separated extra trusted origins for BetterAuth (if you split frontend
# onto a separate domain later).
TRUSTED_ORIGINS=

# ─── Cloudinary direct upload (for ad image/video upload) ────────────────────

# Browser uploads images/videos straight to Cloudinary (no server proxy).
# Needs an *unsigned* upload preset configured at cloudinary.com:
#   1. Dashboard → Settings → Upload → "Upload presets" → Add upload preset
#   2. Signing Mode: Unsigned
#   3. Set folder (e.g. addisonx/ads), max file size, allowed formats
#   4. Save → copy the Preset name
# Cloud name is shown on Cloudinary dashboard top-left ("Cloud name").
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=
# Optional size caps (defaults: 25 MB image, 100 MB video)
CLOUDINARY_MAX_IMAGE_MB=
CLOUDINARY_MAX_VIDEO_MB=

# ─── Cloudinary (drag-and-drop image/video upload in the Ads wizard) ──────────
#
# Both values are needed to enable the "Upload" tab on the ad creative step.
# When blank, the wizard falls back to URL-paste only.
#
# 1) Sign up at cloudinary.com (free 25GB tier is plenty for SMBs)
# 2) Dashboard → top right shows "Cloud name" — paste here
# 3) Settings (gear) → Upload tab → Add upload preset → Mode: UNSIGNED
#    Recommended preset settings:
#      - Folder: addisonx/ads
#      - Allowed formats: jpg, png, webp, mp4, mov
#      - Max file size: 25 MB (image), 100 MB (video)
#      - Eager transformation: c_fill,w_1200,h_628 (Meta's recommended dim)
# 4) Copy the preset name and paste here

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=
